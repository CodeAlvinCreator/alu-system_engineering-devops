#!/usr/bin/env bash
# Configures Nginx to serve a custom 404 page containing
# "Ceci n'est pas une page"

apt-get update -y
apt-get install -y nginx

echo "Hello World!" > /var/www/html/index.html

# Create the custom 404 page safely using a heredoc
cat > /var/www/html/404.html << 'EOF'
Ceci n'est pas une page
EOF

# Insert error_page directive right after server_name _;
sed -i '/server_name _;/a\
\terror_page 404 /404.html;' /etc/nginx/sites-available/default

service nginx start
service nginx restart

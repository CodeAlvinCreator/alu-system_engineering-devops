#!/usr/bin/env bash
# Configures HAProxy on a fresh Ubuntu machine to load balance
# traffic across web-01 and web-02 using round-robin.

set -e

# Update package list and install HAProxy
apt-get update -y
apt-get install -y haproxy

# Back up the original config just in case
cp /etc/haproxy/haproxy.cfg /etc/haproxy/haproxy.cfg.bak

# Append frontend/backend config
cat >> /etc/haproxy/haproxy.cfg <<EOF

frontend Chidera_lb
    bind *:80
    mode http
    default_backend Chidera_backend

backend Chidera_backend
    balance roundrobin
    server Chidera-web-01 44.206.242.109:80 check
    server Chidera-web-02 52.207.239.117:80 check
EOF

# Enable HAProxy to be managed via the init script
if grep -q "^ENABLED=" /etc/default/haproxy; then
    sed -i 's/^ENABLED=.*/ENABLED=1/' /etc/default/haproxy
else
    echo "ENABLED=1" >> /etc/default/haproxy
fi

# Restart HAProxy to apply changes
service haproxy restart
